{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client", "vitest/globals"],
    "jsx": "react-jsx",
    "noEmit": true,
    "rootDir": "."
  },
  "include": ["viewer/**/*.ts", "viewer/**/*.tsx", "vite.viewer.config.ts"],
  "exclude": ["dist", "node_modules"]
}
